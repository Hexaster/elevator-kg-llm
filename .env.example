# Copy to .env and fill in. Never commit real keys.
# LLM endpoint used for KG completion / retrieve-then-verify / QA generation
LLM_API_KEY=
LLM_BASE_URL=http://localhost:8000/v1
# Embedding API used for the optional sentence-cosine evaluation (utils.embedding_eval)
DASHSCOPE_API_KEY=
# Local path or HuggingFace id of the sentence-embedding model used for entity alignment
EMBEDDING_MODEL_PATH=Qwen/Qwen3-Embedding-0.6B
# Directory holding the (proprietary, not distributed) data files
DATA_DIR=./data
